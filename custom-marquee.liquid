<style>
  .custom-marquee-container-{{ section.id }} {
    overflow: hidden;
    white-space: nowrap;
    width: 100%;
    background-color: {{ section.settings.bg_color }};
    padding: 12px 0;
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .custom-marquee-track-{{ section.id }} {
    display: flex;
    width: max-content;
    /* Uses the dynamic speed setting from the schema */
    animation: marquee-scroll-{{ section.id }} {{ section.settings.scroll_speed }}s linear infinite;
  }

  .custom-marquee-track-{{ section.id }}:hover {
    animation-play-state: paused;
  }

  .custom-marquee-group-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 40px; 
    padding-right: 40px; 
  }

  .custom-marquee-item-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    color: {{ section.settings.text_color }};
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .custom-marquee-item-{{ section.id }} svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @keyframes marquee-scroll-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<div class="custom-marquee-container-{{ section.id }}">
  <div class="custom-marquee-track-{{ section.id }}">
    
    <div class="custom-marquee-group-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="custom-marquee-item-{{ section.id }}" {{ block.shopify_attributes }}>
          {%- if block.settings.icon_svg != blank -%}
            {{ block.settings.icon_svg }}
          {%- endif -%}
          
          {%- if block.settings.text != blank -%}
            <span>{{ block.settings.text }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="custom-marquee-group-{{ section.id }}" aria-hidden="true">
      {%- for block in section.blocks -%}
        <div class="custom-marquee-item-{{ section.id }}">
          {%- if block.settings.icon_svg != blank -%}
            {{ block.settings.icon_svg }}
          {%- endif -%}
          
          {%- if block.settings.text != blank -%}
            <span>{{ block.settings.text }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Marquee",
  "settings": [
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Scroll Speed",
      "default": 25
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text/Icon Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "marquee_item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon (SVG Code)",
          "info": "Paste your raw <svg> code here."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Caramelized Chilli Oil"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Marquee",
      "blocks": [
        { "type": "marquee_item" },
        { "type": "marquee_item" },
        { "type": "marquee_item" }
      ]
    }
  ]
}
{% endschema %}
